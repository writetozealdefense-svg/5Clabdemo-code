# REQUIRED: Your GCP Project ID
project_id = "YOUR_GCP_PROJECT_ID"

# OPTIONAL: Override defaults if needed
# region       = "us-central1"
# zone         = "us-central1-a"
# cluster_name = "vuln-gke-cluster"
# node_count   = 2
# machine_type = "e2-standard-4"
